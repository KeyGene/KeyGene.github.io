---
import { ViewTransitions } from 'astro:transitions';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import Toast from '../islands/Toast.tsx';
import CommandPalette from '../islands/CommandPalette.tsx';
import { t } from '../i18n/utils';
import '../styles/tokens.css';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const { title, description, ogImage } = Astro.props;
const lang = Astro.currentLocale ?? 'zh';
const desc = description ?? '';
const og = ogImage ?? 'https://keygene.top/assert/images/hero-bg.jpg';

const pathname = Astro.url.pathname;
const basePath = pathname.replace(/^\/(en|ko)(?=\/|$)/, '') || '/';
const localized = (locale: string) => {
  if (locale === 'zh') return basePath;
  return basePath === '/' ? `/${locale}` : `/${locale}${basePath}`;
};
const hreflangs = [
  { lang: 'zh-CN', href: `https://keygene.top${localized('zh')}` },
  { lang: 'en', href: `https://keygene.top${localized('en')}` },
  { lang: 'ko', href: `https://keygene.top${localized('ko')}` },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'KeyGene',
  url: 'https://keygene.top',
  description: desc || t('siteDesc', lang),
  inLanguage: ['zh-CN', 'en', 'ko'],
};

const cmdItems = [
  { id: 'stats', title: t('navStatsLookup', lang), section: t('cmdPages', lang), href: '/stats' },
  { id: 'maps', title: t('navMapsInteractive', lang), section: t('cmdPages', lang), href: '/maps' },
  { id: 'quiz', title: t('navQuiz', lang), section: t('cmdPages', lang), href: '/quiz' },
  { id: 'sens', title: t('navSensitivity', lang), section: t('cmdTools', lang), href: '/sensitivity' },
  { id: 'weapons', title: t('navWeapons', lang), section: t('cmdTools', lang), href: '/weapons' },
  { id: 'team', title: t('navTeam', lang), section: t('cmdTools', lang), href: '/team' },
  { id: 'flight', title: t('navFlight', lang), section: t('cmdTools', lang), href: '/flight' },
];
const cmdLabels = {
  cmdPlaceholder: t('cmdPlaceholder', lang),
  cmdNoResults: t('cmdNoResults', lang),
};
---

<!DOCTYPE html>
<html lang={lang === 'zh' ? 'zh-CN' : lang}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  {desc && <meta name="description" content={desc} />}
  <meta name="keywords" content={t('metaKeywords', lang)} />
  <meta name="robots" content="index, follow" />
  <meta property="og:title" content={title} />
  {desc && <meta property="og:description" content={desc} />}
  <meta property="og:image" content={og} />
  <meta property="og:image:width" content="1440" />
  <meta property="og:image:height" content="828" />
  <meta property="og:image:alt" content={title} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={Astro.url.href} />
  <meta property="og:site_name" content="KeyGene" />
  <meta property="og:locale" content={lang === 'zh' ? 'zh_CN' : lang === 'ko' ? 'ko_KR' : 'en_US'} />
  <meta property="og:locale:alternate" content="zh_CN" />
  <meta property="og:locale:alternate" content="en_US" />
  <meta property="og:locale:alternate" content="ko_KR" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  {desc && <meta name="twitter:description" content={desc} />}
  <meta name="twitter:image" content={og} />
  <link rel="canonical" href={Astro.url.href} />
  {hreflangs.map(h => <link rel="alternate" hreflang={h.lang} href={h.href} />)}
  <link rel="alternate" hreflang="x-default" href={`https://keygene.top${localized('zh')}`} />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  <link rel="icon" href="/assert/images/favicon.ico" type="image/x-icon" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="dns-prefetch" href="https://unpkg.com" />
  <link rel="dns-prefetch" href="https://cdn.jsdelivr.net" />
  <link href="https://fonts.googleapis.com/css2?family=Rubik:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
  <slot name="head" />
  <ViewTransitions />
  <script is:inline>
    (function() {
      var t = localStorage.getItem('keygene_theme');
      if (t === 'light') document.documentElement.setAttribute('data-theme', 'light');
    })();
  </script>
  <script is:inline>
    // One-shot eviction: kill stale Service Worker + workbox caches from
    // pre-2026-04-25 'prompt'-mode builds. Bump APP_VERSION on future deploys
    // that need a forced client reset.
    (async function() {
      var APP_VERSION = '2026-04-25-flatfile';
      try {
        if (localStorage.getItem('app_version') === APP_VERSION) return;
        var didCleanup = false;
        if ('serviceWorker' in navigator) {
          var regs = await navigator.serviceWorker.getRegistrations();
          if (regs.length > 0) {
            await Promise.all(regs.map(function(r) { return r.unregister(); }));
            didCleanup = true;
          }
        }
        if ('caches' in window) {
          var keys = await caches.keys();
          if (keys.length > 0) {
            await Promise.all(keys.map(function(k) { return caches.delete(k); }));
            didCleanup = true;
          }
        }
        localStorage.setItem('app_version', APP_VERSION);
        if (didCleanup) location.reload();
      } catch (e) {}
    })();
  </script>
  <style>
    .skip-nav {
      position: absolute;
      top: -100%;
      left: var(--space-md);
      padding: var(--space-sm) var(--space-md);
      background: var(--color-primary);
      color: #fff;
      border-radius: var(--radius-md);
      z-index: 999;
      font-size: var(--text-sm);
      text-decoration: none;
    }
    .skip-nav:focus { top: var(--space-md); }

    @keyframes toast-in {
      from { opacity: 0; transform: translateY(12px); }
      to { opacity: 1; transform: translateY(0); }
    }
    @keyframes toast-progress {
      from { width: 100%; }
      to { width: 0%; }
    }
  </style>
</head>
<body>
  <a href="#main-content" class="skip-nav">{t('skipNav', lang)}</a>
  <Nav />
  <main id="main-content" tabindex="-1" transition:animate="fade" style={`min-height: calc(100dvh - 160px); padding-top: var(--header-height);`}>
    <slot />
  </main>
  <Footer />
  <Toast client:idle />
  <CommandPalette client:idle items={cmdItems} labels={cmdLabels} />
  <script>
    let gPressed = false;
    let gTimeout: number = 0;
    let kbdBound = false;

    function onKeydown(e: KeyboardEvent) {
      const tag = (e.target as HTMLElement).tagName;
      if (tag === 'INPUT' || tag === 'TEXTAREA') return;

      if (e.key === 'g' && !e.metaKey && !e.ctrlKey) {
        gPressed = true;
        clearTimeout(gTimeout);
        gTimeout = window.setTimeout(() => { gPressed = false; }, 500);
        return;
      }

      if (gPressed) {
        gPressed = false;
        const routes: Record<string, string> = { s: '/stats', m: '/maps', q: '/quiz' };
        if (routes[e.key]) {
          e.preventDefault();
          window.location.href = routes[e.key];
        }
      }
    }

    document.addEventListener('astro:page-load', () => {
      if (kbdBound) return;
      kbdBound = true;
      document.addEventListener('keydown', onKeydown);
    });
  </script>
</body>
</html>
