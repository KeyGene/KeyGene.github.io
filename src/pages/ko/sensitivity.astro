---
import Base from '../../layouts/Base.astro';
import SensCalc from '../../islands/SensCalc.tsx';
import { t } from '../../i18n/utils';
const lang = Astro.currentLocale ?? 'zh';

const labels = {
  sens: t('sensSens', lang),
  vRatio: t('sensVRatio', lang),
  scopeSens: t('sensScopeSens', lang),
  cm360: t('sensCm360', lang),
  calcTitle: t('sensCalcTitle', lang),
  proSettings: t('sensProSettings', lang),
  filterAll: t('sensFilterAll', lang),
  filterLow: t('sensFilterLow', lang),
  filterHigh: t('sensFilterHigh', lang),
  apply: t('sensApply', lang),
  copyLink: t('sensCopyLink', lang),
  shareCard: t('sensShareCard', lang),
  dpiConvert: t('sensDpiConvert', lang),
  newDpi: t('sensNewDpi', lang),
  equivSens: t('sensEquivSens', lang),
  copied: t('sensCopied', lang),
  loading: t('loadingDots', lang),
};
---

<Base title={t('sensTitle', lang)} description={t('sensDesc', lang)}>
  <div class="sens-hero">
    <div class="sens-hero-tag">{t('sensHeroTag', lang)}</div>
    <h1 class="sens-hero-title" set:html={t('sensHeroTitle', lang)} />
    <p class="sens-hero-sub">{t('sensHeroSub', lang)}</p>
  </div>

  <script is:inline defer src="https://cdn.jsdelivr.net/npm/html2canvas@1.4.1/dist/html2canvas.min.js"></script>
  <SensCalc client:visible labels={labels} />
</Base>

<style>
  .sens-hero {
    padding: 48px 24px 32px;
    text-align: center;
  }
  .sens-hero-tag {
    display: inline-flex; align-items: center; gap: 8px;
    font-size: var(--text-xs); font-weight: 600; letter-spacing: 0.12em;
    text-transform: uppercase; color: var(--color-red); margin-bottom: var(--space-md);
  }
  .sens-hero-tag::before { content: ''; width: 24px; height: 2px; background: var(--color-red); }
  .sens-hero-title {
    font-size: var(--text-3xl); font-weight: 800; letter-spacing: -0.04em;
    text-transform: uppercase; line-height: 1.1; margin-bottom: 10px;
  }
  :global(.sens-hero-title .accent) { color: var(--color-red); }
  .sens-hero-sub { font-size: var(--text-base); color: var(--color-text-muted); }

  @media (max-width: 900px) {
    .sens-hero { padding: 32px 24px 24px; }
    .sens-hero-title { font-size: var(--text-2xl); }
  }
</style>
