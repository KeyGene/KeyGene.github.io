---
import Base from '../../layouts/Base.astro';
import QuizEngine from '../../islands/QuizEngine.tsx';
import { t } from '../../i18n/utils';
import { QUESTIONS } from '../../data/quiz';

const lang = (Astro.currentLocale ?? 'ko') as 'zh' | 'en' | 'ko';

const labels = {
  quizTag: t('quizTag', lang),
  quizTitle1: t('quizTitle1', lang),
  quizTitle2: t('quizTitle2', lang),
  quizSub: t('quizSub', lang),
  quizStart: t('quizStart', lang),
  quizCounterText: t('quizCounterText', lang),
  quizLastResult: t('quizLastResult', lang),
  quizPrev: t('quizPrev', lang),
  quizAgree: t('quizAgree', lang),
  quizDisagree: t('quizDisagree', lang),
  quizCounterFmt: t('quizCounterFmt', lang),
  quizLikertA3: t('quizLikertA3', lang),
  quizLikertA2: t('quizLikertA2', lang),
  quizLikertA1: t('quizLikertA1', lang),
  quizLikertN:  t('quizLikertN',  lang),
  quizLikertD1: t('quizLikertD1', lang),
  quizLikertD2: t('quizLikertD2', lang),
  quizLikertD3: t('quizLikertD3', lang),
};
---

<Base title={t('quizTitle', lang)} description={t('quizSub', lang)}>
  <QuizEngine
    client:visible
    questions={QUESTIONS}
    lang={lang}
    labels={labels}
  />
</Base>
