---
import Base from '../../layouts/Base.astro';
import QuizEngine from '../../islands/QuizEngine.tsx';
import { t } from '../../i18n/utils';
import { QUESTIONS, PERSONALITY_TYPES, GROUP_COLORS, GROUP_INFO, DIMENSION_LABELS } from '../../data/quiz';

const lang = Astro.currentLocale ?? 'zh';

const labels = {
  quizTag: t('quizTag', lang),
  quizTitle1: t('quizTitle1', lang),
  quizTitle2: t('quizTitle2', lang),
  quizSub: t('quizSub', lang),
  quizStart: t('quizStart', lang),
  quizCounterText: t('quizCounterText', lang),
  quizLastResult: t('quizLastResult', lang),
  quizPrev: t('quizPrev', lang),
  quizNext: t('quizNext', lang),
  quizViewResult: t('quizViewResult', lang),
  resultLabel: t('resultLabel', lang),
  resultGroupLabel: t('resultGroupLabel', lang),
  resultStrengths: t('resultStrengths', lang),
  resultWeaknesses: t('resultWeaknesses', lang),
  resultPartner: t('resultPartner', lang),
  resultNemesis: t('resultNemesis', lang),
  resultRetry: t('resultRetry', lang),
  resultShare: t('resultShare', lang),
  shareSave: t('shareSave', lang),
  shareClose: t('shareClose', lang),
  resultViewAll: t('resultViewAll', lang),
  allTypesTitle: t('allTypesTitle', lang),
};
---

<Base title={t('quizTitle', lang)} description={t('quizSub', lang)}>
  <div style="max-width:640px;margin:0 auto;">
    <QuizEngine
      client:visible
      questions={QUESTIONS}
      types={PERSONALITY_TYPES}
      groupColors={GROUP_COLORS}
      groupInfo={GROUP_INFO}
      dimensionLabels={DIMENSION_LABELS}
      lang={lang}
      labels={labels}
    />
  </div>
</Base>
