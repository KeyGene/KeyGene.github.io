---
import Base from '../layouts/Base.astro';
import FlightSim from '../islands/FlightSim.tsx';
import { t } from '../i18n/utils';
const lang = Astro.currentLocale ?? 'zh';

const labels = {
  mapSelect: t('flightMapSelect', lang),
  flightInfo: t('flightInfo', lang),
  recommended: t('flightRecommended', lang),
  clear: t('flightClear', lang),
  share: t('flightShare', lang),
  clickHint: t('flightClickHint', lang),
  clickEnd: t('flightClickEnd', lang),
  distance: t('flightDistance', lang),
  flightTime: t('flightTime', lang),
  mapLabel: t('flightMapLabel', lang),
  loot: t('flightLoot', lang),
  lang,
};
---

<Base title={t('flightTitle', lang)} description={t('flightDesc', lang)}>
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" slot="head" />
  <script is:inline src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" slot="head"></script>

  <div style="max-width:1400px;margin:0 auto;">
    <FlightSim client:load labels={labels} />
  </div>

  <style>
    .flight-page { display: flex; height: calc(100vh - 160px); }
    .flight-sidebar {
      width: 320px; background: var(--color-bg); border-right: 1px solid var(--color-border);
      overflow-y: auto; padding: var(--space-lg); flex-shrink: 0;
    }
    .flight-map { flex: 1; position: relative; }
    #leafletMap { width: 100%; height: 100%; background: #111; }

    .sidebar-section { margin-bottom: var(--space-lg); }
    .sidebar-label {
      display: inline-flex; align-items: center; gap: var(--space-sm);
      font-size: var(--text-xs); font-weight: 600; letter-spacing: 0.1em;
      text-transform: uppercase; color: var(--color-red); margin-bottom: var(--space-md);
    }
    .sidebar-label::before { content: ''; width: 16px; height: 2px; background: var(--color-red); }

    .map-item {
      display: flex; align-items: center; gap: 10px; padding: 10px;
      background: var(--color-surface); border: 1px solid var(--color-border);
      border-radius: var(--radius-md); margin-bottom: 6px; cursor: pointer; transition: border-color 0.2s;
    }
    .map-item:hover, .map-item.active { border-color: var(--color-red); }
    .map-item .dot { width: 8px; height: 8px; border-radius: 50%; background: var(--color-text-muted); flex-shrink: 0; }
    .map-item.active .dot { background: var(--color-red); }
    .map-item .name { font-size: var(--text-sm); font-weight: 600; }

    .flight-info {
      background: var(--color-card-bg); border: 1px solid var(--color-card-border);
      border-radius: var(--radius-lg); padding: var(--space-md);
    }
    .info-row { display: flex; justify-content: space-between; padding: 6px 0; font-size: var(--text-sm); }
    .info-row .label { color: var(--color-text-muted); }
    .info-row .value { font-weight: 700; }
    .info-hint { font-size: 12px; color: var(--color-text-muted); margin-top: var(--space-sm); }

    .drop-item {
      display: flex; align-items: center; gap: 12px; padding: 12px;
      background: var(--color-surface); border: 1px solid var(--color-border);
      border-radius: var(--radius-md); margin-bottom: var(--space-sm); cursor: pointer; transition: border-color 0.2s;
    }
    .drop-item:hover { border-color: var(--color-red); }
    .drop-rank {
      width: 26px; height: 26px; border-radius: 50%; background: var(--color-red);
      color: #fff; display: flex; align-items: center; justify-content: center;
      font-size: 12px; font-weight: 800; flex-shrink: 0;
    }
    .drop-info { flex: 1; }
    .drop-name { font-size: var(--text-sm); font-weight: 700; }
    .drop-meta { font-size: var(--text-xs); color: var(--color-text-muted); margin-top: 2px; }
    .drop-dist { font-size: var(--text-sm); font-weight: 700; flex-shrink: 0; }
    .drop-dist.near { color: #10B981; }
    .drop-dist.mid { color: #F59E0B; }
    .drop-dist.far { color: var(--color-red); }

    .sidebar-actions { display: flex; gap: var(--space-sm); }
    .sidebar-btn {
      flex: 1; padding: 10px; border: none; border-radius: var(--radius-md);
      font-family: var(--font-sans); font-size: 12px; font-weight: 700; cursor: pointer;
    }
    .sidebar-btn-red { background: var(--color-red); color: #fff; }
    .sidebar-btn-red:hover { background: var(--color-red-hover); }
    .sidebar-btn-outline {
      background: transparent; color: var(--color-text);
      border: 1px solid var(--color-border);
    }
    .sidebar-btn-outline:hover { border-color: var(--color-text-muted); }

    @media (max-width: 768px) {
      .flight-page { flex-direction: column; height: auto; }
      .flight-sidebar { width: 100%; height: auto; border-right: none; border-bottom: 1px solid var(--color-border); max-height: 40vh; }
      .flight-map { height: 60vh; }
    }
  </style>
</Base>
