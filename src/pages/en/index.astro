---
import Base from '../../layouts/Base.astro';
import Hero from '../../components/Hero.astro';
import ServerStatus from '../../components/ServerStatus.astro';
import { t } from '../../i18n/utils';
const lang = Astro.currentLocale ?? 'zh';
---

<Base title={t('siteTitle', lang)} description={t('siteDesc', lang)}>
  <div class="homepage">
    <Hero />
    <ServerStatus />

    <!-- ===== ABOUT ===== -->
    <section id="about" class="reveal" transition:name="about">
      <div class="section-inner">
        <div class="section-tag">{t('aboutTag', lang)}</div>
        <div class="about-grid">
          <div>
            <h2 class="section-title" set:html={t('aboutTitle2', lang)} />
            <div class="about-text">
              <p set:html={t('aboutP1', lang)} />
              <p>{t('aboutP2', lang)}</p>
            </div>
          </div>
          <div class="about-visual">
            <picture>
              <source srcset="/assert/images/about-team.webp" type="image/webp" />
              <img src="/assert/images/about-team.jpg" alt="KEY GENE PUBG" style="width:100%;height:100%;object-fit:cover;border-radius:12px;" />
            </picture>
          </div>
        </div>
      </div>
    </section>

    <!-- ===== ROSTER ===== -->
    <section id="roster" class="roster-section" transition:name="roster">
      <div class="section-inner">
        <div class="section-tag">{t('rosterTag', lang)}</div>
        <h2 class="section-title">{t('rosterTitle', lang)}</h2>

        <div id="clanInfo" class="clan-info">
          <div class="stat-card">
            <div class="stat-card-icon">🏰</div>
            <div class="stat-card-value" id="clanName">--</div>
            <div class="stat-card-label">{t('clanNameLabel', lang)}</div>
          </div>
          <div class="stat-card">
            <div class="stat-card-icon">🏷️</div>
            <div class="stat-card-value" id="clanTag">--</div>
            <div class="stat-card-label">{t('clanTagLabel', lang)}</div>
          </div>
          <div class="stat-card">
            <div class="stat-card-icon">⭐</div>
            <div class="stat-card-value" id="clanLevel">--</div>
            <div class="stat-card-label">{t('clanLevelLabel', lang)}</div>
          </div>
          <div class="stat-card">
            <div class="stat-card-icon">👥</div>
            <div class="stat-card-value" id="clanMembers">--</div>
            <div class="stat-card-label">{t('clanMembersLabel', lang)}</div>
          </div>
        </div>

        <div class="roster-grid" id="rosterGrid"></div>
      </div>
    </section>

    <!-- ===== STATS QUERY ===== -->
    <section id="stats" class="stats-section reveal" transition:name="stats-query">
      <div class="section-inner">
        <div class="section-tag">{t('statsTag', lang)}</div>
        <h2 class="section-title">{t('statsQueryTitle', lang)}</h2>

        <div class="stats-query-box">
          <form id="playerForm" class="stats-form">
            <input
              type="text"
              id="playerName"
              class="stats-input"
              placeholder={t('searchPlaceholder', lang)}
              required
            />
            <button type="submit" class="btn-clip btn-red">{t('searchBtn', lang)}</button>
          </form>
          </div>
        </div>
      </div>
    </section>

    <!-- ===== JOIN ===== -->
    <section id="join" class="join-section reveal" transition:name="join">
      <div class="section-tag">{t('joinTag', lang)}</div>
      <h2 class="section-title" set:html={t('joinTitle2', lang)} />
      <p class="join-desc">{t('joinDesc', lang)}</p>
      <div class="join-actions">
        <a href="mailto:keygene@hotmail.com" class="btn-clip btn-red">{t('joinBtn1', lang)}</a>
        <a href="/stats/" class="btn-clip btn-outline">{t('joinBtn2', lang)}</a>
      </div>
      <p class="join-email">
        <span>{t('joinOr', lang)}</span> <a href="mailto:keygene@hotmail.com">keygene@hotmail.com</a>
      </p>
    </section>
  </div>

  <!-- Scroll reveal -->
  <script is:inline>
    (function() {
      var reveals = document.querySelectorAll('.reveal');
      var observer = new IntersectionObserver(function(entries) {
        entries.forEach(function(e) {
          if (e.isIntersecting) e.target.classList.add('visible');
        });
      }, { threshold: 0.15 });
      reveals.forEach(function(el) { observer.observe(el); });
    })();
  </script>

  <!-- Player search redirect -->
  <script is:inline>
    (function() {
      var form = document.getElementById('playerForm');
      if (form) {
        form.addEventListener('submit', function(e) {
          e.preventDefault();
          var name = document.getElementById('playerName').value.trim();
          if (name) {
            window.location.href = '/stats/?player=' + encodeURIComponent(name);
          }
        });
      }
    })();
  </script>

  <!-- Clan & roster loader -->
  <script is:inline>
    (function() {
      var PUBG_PROXY = '/api';
      var SHARD = 'steam';
      var CLAN_ID = 'clan.c674616417f749be98b20b53e7b01edf';
      var CLAN_MEMBERS = ['SymarsYoung', 'Alrscw'];
      var rosterSection = document.getElementById('roster');
      if (rosterSection) rosterSection.style.display = 'none';

      var colors = [
        'linear-gradient(135deg, #EE3F2C, #ff5a4a)',
        'linear-gradient(135deg, #ff6b35, #ffa500)',
        'linear-gradient(135deg, #c0392b, #e74c3c)',
        'linear-gradient(135deg, #8e44ad, #c0392b)'
      ];

      async function loadClanData() {
        var headers = { Accept: 'application/vnd.api+json' };
        var clanOk = false, membersOk = false;
        var currentSeason = '';

        try {
          var sr = await fetch(PUBG_PROXY + '/shards/' + SHARD + '/seasons', { headers: headers });
          if (sr.ok) {
            var seasons = (await sr.json()).data;
            var cur = seasons.find(function(s) { return s.attributes.isCurrentSeason; });
            if (cur) currentSeason = cur.id;
          }
        } catch(e) {}

        try {
          var r = await fetch(PUBG_PROXY + '/shards/' + SHARD + '/clans/' + CLAN_ID, { headers: headers });
          if (r.ok) {
            var c = (await r.json()).data.attributes;
            document.getElementById('clanName').textContent = c.clanName;
            document.getElementById('clanTag').textContent = c.clanTag;
            document.getElementById('clanLevel').textContent = 'Lv.' + c.clanLevel;
            document.getElementById('clanMembers').textContent = c.clanMemberCount;
            clanOk = true;
          }
        } catch(e) {}

        var cards = [];
        for (var i = 0; i < CLAN_MEMBERS.length; i++) {
          var name = CLAN_MEMBERS[i];
          try {
            var r1 = await fetch(PUBG_PROXY + '/shards/' + SHARD + '/players?filter[playerNames]=' + name, { headers: headers });
            if (!r1.ok) continue;
            var pid = (await r1.json()).data[0].id;
            var r2 = await fetch(PUBG_PROXY + '/shards/' + SHARD + '/players/' + pid + '/seasons/lifetime', { headers: headers });
            var s = (await r2.json()).data.attributes.gameModeStats.squad;
            var kd = s.losses > 0 ? (s.kills / s.losses).toFixed(2) : '∞';
            var wr = s.roundsPlayed > 0 ? (s.wins / s.roundsPlayed * 100).toFixed(1) : '0';

            cards.push(
              '<div class="roster-card">' +
              '<div class="roster-avatar" style="background:' + colors[i % colors.length] + '">' + name[0].toUpperCase() + '</div>' +
              '<div class="roster-name">' + name + '</div>' +
              '<div class="roster-role">' + s.roundsPlayed + ' Matches</div>' +
              '<div style="display:flex;gap:8px;justify-content:center;flex-wrap:wrap;">' +
              '<div class="roster-stat">K/D <span class="val">' + kd + '</span></div>' +
              '<div class="roster-stat">Win <span class="val">' + wr + '%</span></div>' +
              '</div></div>'
            );
          } catch(e) { continue; }
        }

        var grid = document.getElementById('rosterGrid');
        if (cards.length > 0) { grid.innerHTML = cards.join(''); membersOk = true; }
        if (!clanOk) { document.getElementById('clanInfo').style.display = 'none'; }
        if (clanOk || membersOk) { rosterSection.style.display = ''; }
        else { setTimeout(loadClanData, 8000); }
      }
      loadClanData();
    })();
  </script>
</Base>

<style>
  /* Hero needs to escape the main padding-top */
  .homepage { margin-top: calc(-1 * var(--header-height)); }

  /* ===== SECTIONS ===== */
  section { padding: 80px 64px; }
  .section-inner { max-width: 1200px; margin: 0 auto; }
  .section-tag {
    display: inline-flex;
    align-items: center;
    gap: var(--space-sm);
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-red);
    margin-bottom: var(--space-md);
  }
  .section-tag::before {
    content: '';
    width: 20px;
    height: 2px;
    background: var(--color-red);
  }
  .section-title {
    font-size: 42px;
    font-weight: 800;
    letter-spacing: -0.03em;
    text-transform: uppercase;
    margin-bottom: var(--space-md);
    line-height: 1.1;
  }
  .section-title :global(.accent) { color: var(--color-red); }

  /* ===== ABOUT ===== */
  .about-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 64px;
    align-items: center;
    margin-top: 40px;
  }
  .about-visual {
    aspect-ratio: 4/3;
    background: var(--color-surface);
    border-radius: var(--radius-lg);
    border: 1px solid var(--color-border);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }
  .about-text p {
    font-size: 16px;
    color: var(--color-text-muted);
    line-height: 1.7;
    margin-bottom: var(--space-md);
  }
  .about-text p :global(strong) { color: var(--color-text); font-weight: 600; }

  /* ===== ROSTER ===== */
  .roster-section { background: var(--color-gray-800); }
  .clan-info {
    display: flex;
    gap: var(--space-xl);
    margin: 24px 0 32px;
    flex-wrap: wrap;
  }
  .stat-card {
    flex: 1;
    min-width: 140px;
    background: var(--color-card-bg);
    border: 1px solid var(--color-card-border);
    border-radius: var(--radius-lg);
    padding: 20px;
    text-align: center;
    transition: transform 0.2s, border-color 0.2s;
  }
  .stat-card:hover {
    transform: translateY(-3px);
    border-color: rgba(238,63,44,0.3);
  }
  .stat-card-icon { font-size: 20px; margin-bottom: var(--space-sm); }
  .stat-card-value {
    font-size: var(--text-2xl);
    font-weight: 800;
    letter-spacing: -0.02em;
    margin-bottom: 2px;
  }
  .stat-card-label {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
  .roster-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: 20px;
    margin-top: 40px;
  }

  /* roster card styles (for JS-injected content) */
  :global(.roster-card) {
    background: var(--color-card-bg);
    border: 1px solid var(--color-card-border);
    border-radius: var(--radius-lg);
    padding: var(--space-lg);
    text-align: center;
    transition: border-color 0.2s, transform 0.2s;
  }
  :global(.roster-card:hover) {
    border-color: rgba(238,63,44,0.4);
    transform: translateY(-4px);
  }
  :global(.roster-avatar) {
    width: 64px; height: 64px; border-radius: 50%;
    margin: 0 auto 14px;
    display: flex; align-items: center; justify-content: center;
    font-size: 24px; font-weight: 800; color: #fff;
  }
  :global(.roster-name) { font-size: 16px; font-weight: 700; margin-bottom: 2px; }
  :global(.roster-role) {
    font-size: 12px; color: var(--color-text-muted);
    text-transform: uppercase; letter-spacing: 0.06em; margin-bottom: 12px;
  }
  :global(.roster-stat) {
    font-size: var(--text-xs); color: var(--color-text-muted);
    padding: 6px 12px; background: var(--color-surface); border-radius: 6px; display: inline-block;
  }
  :global(.roster-stat .val) { color: var(--color-red); font-weight: 700; }

  /* ===== STATS SECTION ===== */
  .stats-section { background: var(--color-surface); }
  .stats-query-box {
    background: var(--color-card-bg);
    border: 1px solid var(--color-card-border);
    border-radius: 16px;
    padding: 40px;
    margin-top: 40px;
  }
  .stats-form { display: flex; gap: var(--space-md); margin-bottom: var(--space-xl); }
  .stats-input {
    flex: 1;
    padding: 14px 20px;
    background: var(--color-card-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    color: var(--color-text);
    font-family: var(--font-sans);
    font-size: 14px;
    outline: none;
    transition: border-color var(--transition-fast);
  }
  .stats-input:focus { border-color: var(--color-red); }
  .stats-input::placeholder { color: var(--color-text-muted); }
  .stats-result-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-md);
  }

  /* ===== JOIN ===== */
  .join-section { text-align: center; padding: 100px 64px; }
  .join-section .section-tag { justify-content: center; }
  .join-section .section-title { margin-bottom: 12px; }
  .join-desc {
    font-size: 16px;
    color: var(--color-text-muted);
    margin-bottom: var(--space-xl);
    max-width: 500px;
    margin-left: auto; margin-right: auto;
    line-height: 1.6;
  }
  .join-actions { display: flex; gap: var(--space-md); justify-content: center; }
  .join-email { margin-top: var(--space-lg); font-size: 14px; color: var(--color-text-muted); }
  .join-email a { color: var(--color-text); text-decoration: underline; transition: color var(--transition-fast); }
  .join-email a:hover { color: var(--color-primary); }

  /* ===== SCROLL ANIMATIONS ===== */
  .reveal {
    opacity: 0;
    transform: translateY(24px);
    transition: opacity 0.6s ease, transform 0.6s ease;
  }
  :global(.reveal.visible) {
    opacity: 1;
    transform: translateY(0);
  }

  /* ===== MOBILE ===== */
  @media (max-width: 768px) {
    .homepage { margin-top: calc(-1 * var(--header-height-mobile)); }
    section { padding: 60px 24px; }
    .section-title { font-size: 32px; }
    .about-grid { grid-template-columns: 1fr; gap: 32px; }
    .roster-grid { grid-template-columns: repeat(2, 1fr); gap: 12px; }
    .stats-form { flex-direction: column; }
    .stats-result-grid { grid-template-columns: repeat(2, 1fr); }
    .join-section { padding: 60px 24px; }
    .join-actions { flex-direction: column; align-items: center; }
  }
</style>
