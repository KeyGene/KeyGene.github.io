---
import Base from '../../layouts/Base.astro';
import WeaponFilter from '../../islands/WeaponFilter.tsx';
import { t } from '../../i18n/utils';
import fs from 'node:fs';
import path from 'node:path';

const lang = Astro.currentLocale ?? 'zh';

const raw = fs.readFileSync(path.join(process.cwd(), 'public/assert/data/weapons.json'), 'utf-8');
const weaponsData = JSON.parse(raw);

const labels = {
  all: t('weaponsAll', lang),
  search: t('weaponsSearch', lang),
  sortDmg: t('weaponsSortDmg', lang),
  sortRof: t('weaponsSortRof', lang),
  sortRng: t('weaponsSortRng', lang),
  detailClose: t('weaponsDetailClose', lang),
  detailReload: t('weaponsDetailReload', lang),
  detailMag: t('weaponsDetailMag', lang),
  detailAttachments: t('weaponsDetailAttachments', lang),
  detailBaseStats: t('weaponsDetailBaseStats', lang),
  detailRecoil: t('weaponsDetailRecoil', lang),
  detailDamage: t('weaponsDetailDamage', lang),
  detailRpm: t('weaponsDetailRpm', lang),
  detailVelocity: t('weaponsDetailVelocity', lang),
  compareTitle: t('weaponsCompareTitle', lang),
  compareClear: t('weaponsCompareClear', lang),
  compareHint: t('weaponsCompareHint', lang),
};
---

<Base title={t('weaponsTitle', lang)} description={t('weaponsDesc', lang)}>
  <script is:inline src="https://cdn.jsdelivr.net/npm/chart.js@4.4.7/dist/chart.umd.min.js" slot="head"></script>
  <section style="padding: 48px 24px 32px; text-align: center;">
    <div style="display: inline-flex; align-items: center; gap: 8px; font-size: 12px; font-weight: 600; letter-spacing: 0.12em; text-transform: uppercase; color: var(--color-red); margin-bottom: 16px;">
      <span style="width: 24px; height: 2px; background: var(--color-red); display: inline-block;"></span>
      {t('weaponsTag', lang)}
    </div>
    <h1 style="font-size: var(--text-3xl); font-weight: 800; letter-spacing: -0.04em; text-transform: uppercase; line-height: 1.1; margin: 0 0 10px;">
      <Fragment set:html={t('weaponsHeroTitle', lang)} />
    </h1>
    <p style="font-size: var(--text-base); color: var(--color-text-muted); margin: 0;">
      {t('weaponsHeroSub', lang)}
    </p>
  </section>

  <WeaponFilter client:visible data={weaponsData} lang={lang} labels={labels} />
</Base>
