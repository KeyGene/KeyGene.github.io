---
import Base from '../../layouts/Base.astro';
import { t } from '../../i18n/utils';
import { PERSONALITY_TYPES, GROUP_INFO, GROUP_COLORS, type GroupId, type Lang, type PersonalityType } from '../../data/quiz';

const lang = (Astro.currentLocale ?? 'zh') as Lang;
const langPrefix = lang === 'zh' ? '' : `/${lang}`;

const groupOrder: GroupId[] = ['rush', 'brain', 'shadow', 'leader'];
const groupDescKeys: Record<GroupId, string> = {
  rush: 'typesGroupRushDesc',
  brain: 'typesGroupBrainDesc',
  shadow: 'typesGroupShadowDesc',
  leader: 'typesGroupLeaderDesc',
};

const typesByGroup: Record<GroupId, PersonalityType[]> = {
  rush: [], brain: [], shadow: [], leader: [],
};
for (const type of Object.values(PERSONALITY_TYPES)) {
  typesByGroup[type.group].push(type);
}

const pageTitle = t('typesTitle', lang);
const pageDesc = t('typesSub', lang);
---

<Base title={pageTitle} description={pageDesc}>
  <style>
    .types-container { max-width: 1100px; margin: 0 auto; padding: 80px clamp(16px, 4vw, 24px) 60px; }
    .types-hero { text-align: center; margin-bottom: 48px; }
    .types-hero-title { font-size: clamp(32px, 6vw, 52px); font-weight: 800; letter-spacing: -0.04em; line-height: 1.1; margin: 0 0 16px; text-transform: uppercase; }
    .types-hero-sub { font-size: clamp(15px, 3vw, 18px); color: var(--color-text-muted); margin: 0 0 32px; }
    .types-group-section { margin-bottom: 48px; }
    .types-group-header { display: flex; align-items: center; gap: 12px; margin-bottom: 8px; }
    .types-group-line { flex-shrink: 0; width: 32px; height: 3px; }
    .types-group-name { font-size: 14px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em; }
    .types-group-desc { font-size: 14px; color: var(--color-text-muted); margin: 0 0 20px; }
    .types-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 12px; }
    @media (max-width: 768px) { .types-grid { grid-template-columns: repeat(2, 1fr); } }
    .type-card {
      background: var(--color-card-bg);
      border: 1px solid var(--color-card-border);
      border-radius: 12px;
      padding: 16px 12px;
      text-decoration: none;
      color: inherit;
      display: block;
      transition: transform 150ms, border-color 150ms;
    }
    .type-card:hover { transform: translateY(-3px); border-color: var(--color-text-muted); }
    @media (prefers-reduced-motion: reduce) {
      .type-card { transition: none !important; }
      .type-card:hover { transform: none !important; }
    }
    .type-card-img { width: 100%; aspect-ratio: 1; border-radius: 8px; overflow: hidden; background: var(--color-surface); margin-bottom: 12px; }
    .type-card-img img { width: 100%; height: 100%; object-fit: contain; }
    .type-card-code { font-size: 14px; font-weight: 700; letter-spacing: 0.1em; text-align: center; }
    .type-card-nickname { font-size: 13px; font-weight: 600; text-align: center; margin: 4px 0 6px; }
    .type-card-tagline { font-size: 11px; color: var(--color-text-muted); text-align: center; line-height: 1.4; }
  </style>

  <div class="types-container">
    <div class="types-hero">
      <h1 class="types-hero-title">{pageTitle}</h1>
      <p class="types-hero-sub">{pageDesc}</p>
      <a href={`${langPrefix}/quiz`} class="btn-clip btn-red" style="font-size:15px;padding:14px 32px;">
        {t('typesCTA', lang)}
      </a>
    </div>

    {groupOrder.map((g) => {
      const color = GROUP_COLORS[g];
      const types = typesByGroup[g];
      return (
        <section class="types-group-section">
          <div class="types-group-header">
            <span class="types-group-line" style={`background:${color};`}></span>
            <span class="types-group-name" style={`color:${color};`}>{GROUP_INFO[g][lang]}</span>
          </div>
          <p class="types-group-desc">{t(groupDescKeys[g], lang)}</p>
          <div class="types-grid">
            {types.map((type) => (
              <a href={`${langPrefix}/quiz/types/${type.code}`} class="type-card">
                <div class="type-card-img">
                  <img src={type.image} alt={type.nickname[lang]} loading="lazy" />
                </div>
                <div class="type-card-code" style={`color:${color};`}>{type.code}</div>
                <div class="type-card-nickname">{type.nickname[lang]}</div>
                <div class="type-card-tagline">{type.tagline[lang]}</div>
              </a>
            ))}
          </div>
        </section>
      );
    })}
  </div>
</Base>
