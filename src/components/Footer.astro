---
import { t } from '../i18n/utils';
const lang = Astro.currentLocale ?? 'zh';
---

<footer>
  <div class="footer-inner">
    <span class="copyright">&copy; <span id="year">{new Date().getFullYear()}</span> KeyGene</span>


  </div>
</footer>

<script is:inline>
  (function() {
    var el = document.getElementById('year');
    if (el) el.textContent = new Date().getFullYear();
  })();
</script>

<style>
  footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 24px 48px;
    border-top: 1px solid var(--color-border);
    font-size: 12px;
    color: var(--color-text-muted);
  }
  .footer-inner {
    width: 100%;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .copyright {
    font-size: 12px;
    color: var(--color-text-muted);
  }
  .footer-links {
    display: flex;
    gap: var(--space-sm);
    font-size: var(--text-sm);
  }
  .footer-links a { color: var(--color-text-muted); }
  .footer-links a:hover { color: var(--color-text); }
  .sep { color: var(--color-border); }
  @media (max-width: 768px) {
    footer { flex-direction: column; gap: 12px; padding: 24px; text-align: center; }
  }
</style>
