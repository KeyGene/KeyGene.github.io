---
import { t } from '../i18n/utils';
import ThemeToggle from '../islands/ThemeToggle.tsx';

const lang = Astro.currentLocale ?? 'zh';
const localePath = (path: string) => lang === 'zh' ? path : `/${lang}${path}`;
const isActive = (path: string) => pagePath.startsWith(path);

// Get current page path without locale prefix for language switcher
const rawPath = Astro.url.pathname;
const pagePath = rawPath.replace(/^\/(en|ko)/, '') || '/';
const langPath = (locale: string) => locale === 'zh' ? pagePath : `/${locale}${pagePath}`;
---

<header>
  <a href={localePath('/')} class="logo" transition:name="logo">
    <img src="/assert/images/helmet-red.png" alt="KEY GENE" width="40" height="40" />
    <span class="logo-text">Key<span class="accent">Gene</span></span>
  </a>

  <nav>
    <div class="nav-dropdown">
      <a href={localePath('/stats')} class:list={['nav-link', { active: isActive('/stats') || isActive('/leaderboard') }]}>{t('navStats', lang)}</a>
      <div class="dropdown-menu">
        <a href={localePath('/stats')}>{t('navStatsLookup', lang)}</a>
        <a href={localePath('/leaderboard')}>{t('navLeaderboard', lang)}</a>
      </div>
    </div>
    <div class="nav-dropdown">
      <a href={localePath('/maps')} class:list={['nav-link', { active: isActive('/maps') || isActive('/flight') }]}>{t('navMaps', lang)}</a>
      <div class="dropdown-menu">
        <a href={localePath('/maps')}>{t('navMapsInteractive', lang)}</a>
        <a href={localePath('/flight')}>{t('navFlight', lang)}</a>
      </div>
    </div>
    <div class="nav-dropdown">
      <a href={localePath('/sensitivity')} class:list={['nav-link', { active: isActive('/sensitivity') || isActive('/weapons') || isActive('/team') }]}>{t('navTools', lang)}</a>
      <div class="dropdown-menu">
        <a href={localePath('/sensitivity')}>{t('navSensitivity', lang)}</a>
        <a href={localePath('/weapons')}>{t('navWeapons', lang)}</a>
        <a href={localePath('/team')}>{t('navTeam', lang)}</a>
      </div>
    </div>
    <a href={localePath('/quiz')} class:list={['nav-link', { active: isActive('/quiz') }]}>{t('navQuiz', lang)}</a>
  </nav>

  <div class="nav-right">
    <ThemeToggle client:load />
    <div class="lang-switcher" id="langSwitcher">
      <a href={langPath('zh')} data-lang="zh" class:list={[{ active: lang === 'zh' }]}>中</a>
      <a href={langPath('en')} data-lang="en" class:list={[{ active: lang === 'en' }]}>EN</a>
      <a href={langPath('ko')} data-lang="ko" class:list={[{ active: lang === 'ko' }]}>한</a>
    </div>
    <a href={localePath('/#join')} class="btn-clip btn-red nav-join" style="padding:8px 20px; font-size:12px;">{t('navJoin', lang)}</a>
    <button class="hamburger" id="hamburgerBtn" aria-label="Menu" aria-expanded="false" aria-controls="mobileNav">
      <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2">
        <line x1="3" y1="6" x2="21" y2="6" /><line x1="3" y1="12" x2="21" y2="12" /><line x1="3" y1="18" x2="21" y2="18" />
      </svg>
    </button>
  </div>
</header>

<!-- Mobile Nav Overlay -->
<div class="mobile-nav" id="mobileNav" role="dialog" aria-modal="true" aria-label="Navigation menu">
  <button class="mobile-nav-close" id="mobileNavClose" aria-label="Close menu">
    <svg viewBox="0 0 24 24" width="28" height="28" fill="none" stroke="currentColor" stroke-width="2">
      <line x1="18" y1="6" x2="6" y2="18" /><line x1="6" y1="6" x2="18" y2="18" />
    </svg>
  </button>
  <div class="mobile-group">
    <span class="mobile-group-label">{t('navStats', lang)}</span>
    <div class="mobile-sub">
      <a href={localePath('/stats')}>{t('navStatsLookup', lang)}</a>
      <a href={localePath('/leaderboard')}>{t('navLeaderboard', lang)}</a>
    </div>
  </div>
  <div class="mobile-group">
    <span class="mobile-group-label">{t('navMaps', lang)}</span>
    <div class="mobile-sub">
      <a href={localePath('/maps')}>{t('navMapsInteractive', lang)}</a>
      <a href={localePath('/flight')}>{t('navFlight', lang)}</a>
    </div>
  </div>
  <div class="mobile-group">
    <span class="mobile-group-label">{t('navTools', lang)}</span>
    <div class="mobile-sub">
      <a href={localePath('/sensitivity')}>{t('navSensitivity', lang)}</a>
      <a href={localePath('/weapons')}>{t('navWeapons', lang)}</a>
      <a href={localePath('/team')}>{t('navTeam', lang)}</a>
    </div>
  </div>
  <a href={localePath('/quiz')} class="mobile-direct">{t('navQuiz', lang)}</a>
</div>

<script>
  function syncLangLinks() {
    const path = window.location.pathname;
    const basePath = path.replace(/^\/(en|ko)(?=\/|$)/, '') || '/';
    const currentLang = path.match(/^\/(en|ko)(?=\/|$)/)?.[1] || 'zh';
    const switcher = document.getElementById('langSwitcher');
    if (!switcher) return;
    switcher.querySelectorAll<HTMLAnchorElement>('a[data-lang]').forEach(a => {
      const lang = a.dataset.lang;
      a.href = lang === 'zh' ? basePath : `/${lang}${basePath}`;
      a.classList.toggle('active', lang === currentLang);
    });
    document.querySelectorAll<HTMLAnchorElement>('a.nav-join').forEach(a => {
      a.href = currentLang === 'zh' ? '/#join' : `/${currentLang}/#join`;
    });
  }

  function setupNav() {
    syncLangLinks();
    const hamburger = document.getElementById('hamburgerBtn') as HTMLElement | null;
    const mobileNav = document.getElementById('mobileNav');
    const mobileClose = document.getElementById('mobileNavClose') as HTMLElement | null;

    function openNav() {
      mobileNav?.classList.add('open');
      document.body.style.overflow = 'hidden';
      hamburger?.setAttribute('aria-expanded', 'true');
    }
    function closeNav() {
      mobileNav?.classList.remove('open');
      document.body.style.overflow = '';
      hamburger?.setAttribute('aria-expanded', 'false');
      hamburger?.focus();
    }

    if (hamburger && !hamburger.dataset.bound) {
      hamburger.dataset.bound = '1';
      hamburger.addEventListener('click', openNav);
    }
    if (mobileClose && !mobileClose.dataset.bound) {
      mobileClose.dataset.bound = '1';
      mobileClose.addEventListener('click', closeNav);
    }
    if (mobileNav && !mobileNav.dataset.escBound) {
      mobileNav.dataset.escBound = '1';
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && mobileNav.classList.contains('open')) closeNav();
      });
    }
    mobileNav?.querySelectorAll<HTMLAnchorElement>('a').forEach(a => {
      if (a.dataset.boundClose) return;
      a.dataset.boundClose = '1';
      a.addEventListener('click', closeNav);
    });
    mobileNav?.querySelectorAll<HTMLElement>('.mobile-group-label').forEach(label => {
      if (label.dataset.bound) return;
      label.dataset.bound = '1';
      label.addEventListener('click', () => {
        label.parentElement?.classList.toggle('open');
      });
    });
  }

  document.addEventListener('astro:page-load', setupNav);
  document.addEventListener('astro:after-swap', syncLangLinks);
</script>

<style>
  header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 1000;
    height: var(--header-height);
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 48px;
    background: var(--header-bg);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-bottom: 1px solid var(--color-border);
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 14px;
    text-decoration: none;
    color: var(--color-text);
  }
  .logo img { object-fit: contain; }
  .logo-text { font-size: 22px; font-weight: 800; letter-spacing: -0.02em; text-transform: uppercase; }
  .logo-text .accent { color: var(--color-red); }

  nav {
    display: flex;
    align-items: center;
    gap: 32px;
  }

  .nav-link {
    color: var(--color-text-muted);
    font-size: 14px;
    font-weight: 500;
    letter-spacing: 0.02em;
    padding: 12px 8px;
    transition: color 0.2s;
    text-decoration: none;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    gap: 4px;
  }
  .nav-dropdown > .nav-link::after {
    content: '';
    display: inline-block;
    width: 0; height: 0;
    border-left: 3.5px solid transparent;
    border-right: 3.5px solid transparent;
    border-top: 4px solid currentColor;
    transition: transform 0.2s;
  }
  .nav-dropdown:hover > .nav-link::after { transform: rotate(180deg); }
  .nav-link:hover { color: var(--color-text); }
  .nav-link.active { color: var(--color-red); }
  .nav-dropdown:hover > .nav-link { color: var(--color-text); }

  .nav-dropdown { position: relative; }
  .dropdown-menu {
    display: none;
    position: absolute;
    top: 100%;
    left: 0;
    min-width: 160px;
    margin-top: 4px;
    padding: 6px 0;
    background: var(--header-bg);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    box-shadow: 0 8px 32px rgba(0,0,0,0.4);
    z-index: 150;
  }
  .dropdown-menu::before {
    content: '';
    position: absolute;
    top: -8px;
    left: 0;
    right: 0;
    height: 8px;
  }
  .nav-dropdown:hover .dropdown-menu,
  .nav-dropdown:focus-within .dropdown-menu { display: block; }
  .dropdown-menu a {
    display: block;
    padding: 10px 20px;
    color: var(--color-text-muted);
    text-decoration: none;
    font-size: 13px;
    font-weight: 500;
    transition: color 0.15s, background 0.15s;
  }
  .dropdown-menu a:hover { background: rgba(255,255,255,0.05); color: var(--color-text); }

  .nav-right {
    display: flex;
    align-items: center;
    gap: 20px;
  }

  .lang-switcher {
    display: flex;
    gap: 2px;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    overflow: hidden;
  }
  .lang-switcher a {
    padding: 4px 8px;
    font-size: var(--text-xs);
    font-weight: 600;
    color: var(--color-text-muted);
    text-decoration: none;
    transition: background var(--transition-fast), color var(--transition-fast);
  }
  .lang-switcher a:hover { background: var(--color-surface-hover); color: var(--color-text); }
  .lang-switcher a.active { background: var(--color-red); color: #fff; }

  .hamburger {
    display: none;
    background: none;
    border: none;
    color: var(--color-text);
    cursor: pointer;
    padding: var(--space-xs);
  }

  /* Mobile nav overlay */
  .mobile-nav {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 200;
    background: rgba(0,0,0,0.95);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 32px;
    overflow-y: auto;
  }
  .mobile-nav.open { display: flex; }

  .mobile-nav-close {
    position: absolute;
    top: var(--space-md);
    right: var(--space-md);
    background: none;
    border: none;
    color: var(--color-text);
    cursor: pointer;
  }

  .mobile-group { text-align: center; }
  .mobile-group-label {
    color: var(--color-text);
    font-size: 24px;
    font-weight: 700;
    letter-spacing: 0.02em;
    text-transform: uppercase;
    cursor: pointer;
    display: block;
  }
  .mobile-sub {
    display: none;
    flex-direction: column;
    gap: 12px;
    margin-top: 12px;
  }
  .mobile-group.open .mobile-sub { display: flex; }
  .mobile-sub a,
  .mobile-direct {
    font-size: 17px;
    font-weight: 500;
    color: var(--color-text-muted);
    text-decoration: none;
    text-transform: none;
  }
  .mobile-sub a:hover,
  .mobile-direct:hover { color: var(--color-red); }
  .mobile-direct {
    font-size: 24px;
    font-weight: 700;
    letter-spacing: 0.02em;
    text-transform: uppercase;
    color: var(--color-text);
  }

  @media (max-width: 768px) {
    header {
      height: var(--header-height-mobile);
      padding: 0 var(--space-md);
    }
    nav { display: none; }
    .lang-switcher { display: none; }
    .nav-join { display: none; }
    .hamburger { display: block; }
    .logo { gap: 8px; }
    .logo img { width: 32px; height: 32px; }
    .logo-text { font-size: 18px; }
  }
</style>
